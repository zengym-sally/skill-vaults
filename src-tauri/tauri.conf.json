{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "SkillVault",
  "version": "0.1.0",
  "identifier": "com.skillvault.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillVault",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "publisher": "SkillVault Team",
    "copyright": "Copyright © 2025 SkillVault. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Manage your skills and knowledge",
    "longDescription": "SkillVault is a desktop application that helps you organize, track, and improve your skills and knowledge base.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "hardenedRuntime": true,
      "dmg": {
        "background": null,
        "windowSize": { "width": 600, "height": 400 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.0-37",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        {
          "driver": "sqlite",
          "name": "default",
          "path": "$APPDATA/.skillvault/vault.db"
        }
      ]
    },
    "shell": {
      "open": true
    }
  }
}
